# SmartBrief нҷҳкІҪ м„Өм • нҢҢмқј
# мӢӨм ң мҡҙмҳҒм—җм„ңлҠ” мқҙ нҢҢмқјмқ„ .gitignoreм—җ м¶”к°Җн•ҳкі  мӢӨм ң к°’мңјлЎң ліҖкІҪн•ҳм„ёмҡ”

# Flask м„Өм •
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# Google Gemini API м„Өм • (мЈј лІҲм—ӯ м—”м§„)
GOOGLE_API_KEY=your-google-gemini-api-key-here

# OpenAI API м„Өм • (м„ нғқмӮ¬н•ӯ - fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Google Maps API м„Өм •
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# нҢҢмқј м—…лЎңл“ң м„Өм •
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=uploads

# лЎңк№… м„Өм •
LOG_LEVEL=INFO
LOG_FILE=logs/smartbrief.log

# лҚ°мқҙн„°лІ мқҙмҠӨ м„Өм • (н–Ҙнӣ„ нҷ•мһҘмҡ©)
# DATABASE_URL=sqlite:///smartbrief.db

# AI лІҲм—ӯ м„Өм •
USE_AI_TRANSLATION=False
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.3

# NOTAM н•„н„°л§Ғ м„Өм •
KOREAN_AIRPORTS=RKSI,RKSS,RKPC,RKPK,RKTU,RKNY,RKJJ
AIRLINE_KEYWORDS=KAL,KOREAN AIR,ASIANA

# мәҗмӢң м„Өм • (н–Ҙнӣ„ нҷ•мһҘмҡ©)
# CACHE_TYPE=simple
# CACHE_DEFAULT_TIMEOUT=300

# ліҙм•Ҳ м„Өм •
SESSION_COOKIE_SECURE=False  # мҡҙмҳҒм—җм„ңлҠ” TrueлЎң ліҖкІҪ
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax